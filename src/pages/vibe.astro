---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BlogTopNav from '../components/blog/BlogTopNav.astro';
import { getSiteConfig } from '../data/site';

const { site, vibe: vibeConfig, theme } = await getSiteConfig();
const palette = theme.palette;
const showTrail = vibeConfig.showTrail;

const vibeEntries = (await getCollection('vibe'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const vibes = await Promise.all(
  vibeEntries.map(async (entry, index) => {
    const { Content } = await render(entry);
    const align = entry.data.align ?? (index % 2 === 0 ? 'left' : 'right');

    return { entry, Content, align };
  }),
);
---

<!doctype html>
<html lang="en" data-palette={palette}>
  <head>
    <BaseHead title={`vibe | ${site.title}`} description="Small fragments of life and coding." />
    <style>
      html {
        scroll-behavior: smooth;
      }

      main {
        width: min(100%, var(--layout-shell-width));
        padding-top: 126px;
      }

      .vibe-shell {
        position: relative;
      }

      .vibe-hero::after {
        position: absolute;
        top: clamp(0.3rem, 1.4vw, 0.72rem);
        right: clamp(0.2rem, 2vw, 1.2rem);
        width: clamp(3.9rem, 7.8vw, 5.4rem);
        height: clamp(2.6rem, 5.2vw, 3.6rem);
        background: currentColor;
        color: color-mix(in srgb, var(--paper-accent) 64%, var(--paper-ink-faint));
        content: '';
        -webkit-mask: url('../assets/icons/flight.svg') center / contain no-repeat;
        mask: url('../assets/icons/flight.svg') center / contain no-repeat;
        opacity: 0.34;
        pointer-events: none;
        transform: rotate(-9deg);
      }

      .vibe-hero {
        position: relative;
        width: 100%;
        margin-bottom: clamp(72px, 10vw, 132px);
      }

      .vibe-title {
        max-width: 560px;
        margin: 0;
        color: var(--paper-ink);
        font-size: clamp(2.32rem, 6.6vw, 4.35rem);
        font-weight: 400;
        line-height: 0.96;
      }

      .vibe-subtitle {
        max-width: 30ch;
        margin: 18px 0 0;
        color: var(--paper-ink-soft);
        font-family: var(--font-article);
        font-size: clamp(0.98rem, 1.7vw, 1.16rem);
        line-height: 1.68;
      }

      .vibe-note {
        max-width: 42ch;
        margin: 14px 0 0;
        color: var(--paper-ink-faint);
        font-family: var(--font-meta);
        font-size: 0.7rem;
        line-height: 1.75;
      }

      .vibe-stream {
        position: relative;
        display: grid;
        gap: clamp(58px, 8vw, 124px);
        padding-bottom: clamp(24px, 7vw, 72px);
      }

      .vibe-thread {
        position: absolute;
        inset: -28px 0 -24px;
        z-index: 0;
        width: 100%;
        height: calc(100% + 52px);
        overflow: visible;
        pointer-events: none;
      }

      .vibe-thread-path,
      .vibe-thread-grain {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        vector-effect: non-scaling-stroke;
      }

      .vibe-thread-path {
        stroke: url('#vibe-pencil-fade');
        stroke-width: 1.45;
        opacity: 0.54;
      }

      .vibe-thread-grain {
        stroke: var(--paper-ink-faint);
        stroke-dasharray: 1 9;
        stroke-width: 1.05;
        filter: url('#vibe-pencil-texture');
        opacity: 0.28;
      }

      .vibe-item {
        position: relative;
        z-index: 1;
        width: min(100%, 620px);
        animation: vibe-arrive 520ms both;
        animation-delay: calc(var(--vibe-index) * 72ms);
      }

      .vibe-dot {
        position: absolute;
        top: 0.5rem;
        width: 0.52rem;
        height: 0.52rem;
        border: 1px solid rgba(144, 153, 143, 0.42);
        border-radius: 999px;
        background:
          radial-gradient(circle at 44% 44%, rgba(144, 153, 143, 0.5) 0 18%, transparent 19%),
          var(--paper-bg);
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--paper-bg) 78%, transparent);
        opacity: 0.72;
      }

      .vibe-item.left {
        justify-self: start;
        text-align: left;
      }

      .vibe-item.left .vibe-dot {
        right: -28px;
      }

      .vibe-item.right {
        justify-self: end;
        text-align: right;
      }

      .vibe-item.right .vibe-dot {
        left: -28px;
      }

      .vibe-item.center {
        justify-self: center;
        text-align: center;
      }

      .vibe-item.center .vibe-dot {
        left: 50%;
        transform: translateX(-50%);
      }

      .vibe-item.sm {
        max-width: 330px;
      }

      .vibe-item.md {
        max-width: 530px;
      }

      .vibe-item.lg {
        max-width: 690px;
      }

      .vibe-item:nth-child(3n + 1) {
        transform: translateX(2vw);
      }

      .vibe-item:nth-child(3n + 2) {
        transform: translateX(-3vw);
      }

      .vibe-item:nth-child(3n) {
        transform: translateX(0);
      }

      .vibe-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0;
        align-items: center;
        margin-bottom: 12px;
        color: var(--paper-ink-faint);
        font-family: var(--font-meta);
        font-size: 0.66rem;
        font-weight: 500;
        line-height: 1.7;
        opacity: 0.78;
      }

      .vibe-item.right .vibe-meta,
      .vibe-item.right .vibe-images {
        justify-content: flex-end;
      }

      .vibe-item.center .vibe-meta,
      .vibe-item.center .vibe-images {
        justify-content: center;
      }

      .vibe-meta > * + *::before,
      .vibe-tags::before {
        margin: 0 8px;
        color: var(--paper-line-strong);
        content: '/';
      }

      .vibe-tags {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0;
      }

      .vibe-tag + .vibe-tag::before {
        margin: 0 6px;
        color: var(--paper-line-strong);
        content: ',';
      }

      .vibe-heading {
        margin: 0 0 10px;
        color: var(--paper-ink);
        font-size: clamp(1.12rem, 2.3vw, 1.56rem);
        font-weight: 400;
        line-height: 1.22;
      }

      .vibe-body {
        color: var(--paper-ink);
        font-family: var(--font-article);
        font-size: clamp(0.94rem, 1.42vw, 1.08rem);
        line-height: 1.9;
      }

      .vibe-body :global(p) {
        margin: 0;
      }

      .vibe-body :global(p + p) {
        margin-top: 0.85em;
      }

      .vibe-body :global(a) {
        color: var(--paper-accent);
        text-underline-offset: 0.2em;
      }

      .vibe-body :global(code) {
        color: var(--paper-accent);
        background: transparent;
      }

      .vibe-images {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: flex-start;
        margin: 16px 0 18px;
      }

      .vibe-image {
        flex: 1 1 210px;
        max-width: min(100%, 420px);
        margin: 0;
        overflow: hidden;
        border-radius: 10px;
        opacity: 0.94;
        rotate: -0.6deg;
      }

      .vibe-image:nth-child(even) {
        rotate: 0.7deg;
      }

      .vibe-image img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 10px;
        filter: saturate(0.86) contrast(0.98);
      }

      .vibe-item.quote .vibe-body {
        color: var(--paper-ink-soft);
        font-size: clamp(1.02rem, 2vw, 1.32rem);
        line-height: 1.72;
      }

      @keyframes vibe-arrive {
        from {
          opacity: 0;
        }

        to {
          opacity: 1;
        }
      }

      @media (max-width: 720px) {
        main {
          padding-top: 94px;
        }

        .vibe-hero::after {
          top: 0.2rem;
          right: 0.4rem;
          width: 3.18rem;
          height: 2.12rem;
        }

        .vibe-hero {
          margin-bottom: 62px;
        }

        .vibe-stream {
          gap: 68px;
        }

        .vibe-thread {
          display: none;
        }

        .vibe-item,
        .vibe-item:nth-child(3n + 1),
        .vibe-item:nth-child(3n + 2),
        .vibe-item:nth-child(3n) {
          justify-self: stretch;
          max-width: none;
          transform: none;
        }

        .vibe-dot {
          display: none;
          top: 0.58rem;
        }

        .vibe-item.left .vibe-dot {
          right: -2px;
          left: auto;
        }

        .vibe-item.right .vibe-dot {
          left: -2px;
          right: auto;
        }

        .vibe-item.center .vibe-dot {
          right: -2px;
          left: auto;
          transform: none;
        }

        .vibe-item.sm {
          max-width: 92%;
        }

        .vibe-item.center,
        .vibe-item.right {
          justify-self: end;
        }

        .vibe-body {
          font-size: 0.96rem;
          line-height: 1.86;
        }

        .vibe-image {
          flex-basis: 100%;
          max-width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <BlogTopNav />
    <main data-pagefind-body>
      <div class="vibe-shell">
        <header class="vibe-hero">
          <h1 class="vibe-title">vibe</h1>
          <p class="vibe-subtitle">small fragments of life &amp; coding.</p>
          <p class="vibe-note">Not formal enough for blog posts, but still part of the story.</p>
        </header>

        <section class="vibe-stream" aria-label="Vibe notes">
          {
            showTrail && (
              <svg class="vibe-thread" aria-hidden="true">
                <defs>
                  <linearGradient id="vibe-pencil-fade" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="var(--paper-ink-faint)" stop-opacity="0" />
                    <stop offset="16%" stop-color="var(--paper-ink-faint)" stop-opacity="0.52" />
                    <stop offset="84%" stop-color="var(--paper-ink-faint)" stop-opacity="0.52" />
                    <stop offset="100%" stop-color="var(--paper-ink-faint)" stop-opacity="0" />
                  </linearGradient>
                  <filter id="vibe-pencil-texture" x="-12%" y="-12%" width="124%" height="124%">
                    <feTurbulence
                      type="fractalNoise"
                      baseFrequency="0.9"
                      numOctaves="2"
                      seed="8"
                      result="grain"
                    />
                    <feDisplacementMap in="SourceGraphic" in2="grain" scale="0.65" />
                  </filter>
                </defs>
                <path class="vibe-thread-path" data-vibe-thread-path />
                <path class="vibe-thread-grain" data-vibe-thread-grain />
              </svg>
            )
          }
          {
            vibes.map(({ entry, Content, align }, index) => (
              <article
                class:list={['vibe-item', align, entry.data.size, entry.data.type]}
                style={`--vibe-index: ${index}`}
              >
                {showTrail && <span class="vibe-dot" data-vibe-dot aria-hidden="true" />}
                <div class="vibe-meta">
                  {entry.data.mood && <span>{entry.data.mood}</span>}
                  {entry.data.location && <span>{entry.data.location}</span>}
                  <FormattedDate date={entry.data.date} />
                  {entry.data.tags.length > 0 && (
                    <span class="vibe-tags">
                      {entry.data.tags.map((tag) => (
                        <span class="vibe-tag">#{tag}</span>
                      ))}
                    </span>
                  )}
                </div>

                {entry.data.title && <h2 class="vibe-heading">{entry.data.title}</h2>}

                {entry.data.images.length > 0 && (
                  <div class="vibe-images" aria-label={`${entry.data.title ?? entry.id} images`}>
                    {entry.data.images.map((image) => (
                      <figure class="vibe-image">
                        <Image
                          src={image}
                          alt=""
                          widths={[360, 520, 720]}
                          sizes="(max-width: 720px) 100vw, 420px"
                        />
                      </figure>
                    ))}
                  </div>
                )}

                <div class="vibe-body">
                  <Content />
                </div>
              </article>
            ))
          }
        </section>
      </div>
    </main>
    <Footer />
    {
      showTrail && (
        <script>import {mountVibeThread} from '../utils/vibe-thread'; mountVibeThread();</script>
      )
    }
  </body>
</html>
