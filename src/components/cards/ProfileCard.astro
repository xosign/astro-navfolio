---
import Icon from '../Icon.astro';

interface Profile {
	name: string;
	handle: string;
	role: string;
	company: string;
	location: string;
	email: string;
	website: string;
	meta: string;
	avatar: string;
}

const { profile } = Astro.props as { profile: Profile };

const details = [
	{ icon: 'building', text: profile.company },
	{ icon: 'map', text: profile.location },
	{ icon: 'mail', text: profile.email, href: `mailto:${profile.email}` },
	{ icon: 'compass', text: profile.website, href: profile.website },
	{ icon: 'repo', text: profile.meta },
];
---

<article class="glass-card profile-card">
	<div class="avatar-wrap">
		<img src={profile.avatar} alt={`${profile.name} GitHub avatar`} width="176" height="176" loading="eager" />
		<span class="status-dot" aria-hidden="true"></span>
	</div>

	<div class="profile-heading">
		<h1>{profile.name}</h1>
		<p>{profile.handle}</p>
		<span><Icon name="sparkle" /> {profile.role}</span>
	</div>

	<ul class="profile-details" aria-label="profile details">
		{details.map((item) => (
			<li>
				<Icon name={item.icon} />
				{item.href ? <a href={item.href}>{item.text}</a> : <span>{item.text}</span>}
			</li>
		))}
	</ul>
</article>

<style>
	.profile-card {
		min-height: 580px;
		padding: 34px 26px;
		text-align: center;
	}

	.avatar-wrap {
		position: relative;
		width: 176px;
		height: 176px;
		margin: 0 auto 22px;
		padding: 12px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.86), 0 18px 38px rgba(48, 78, 103, 0.12);
	}

	.avatar-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: inherit;
	}

	.status-dot {
		position: absolute;
		right: 22px;
		bottom: 22px;
		width: 24px;
		height: 24px;
		border: 5px solid #fff;
		border-radius: 50%;
		background: #29ca7a;
		box-shadow: 0 8px 18px rgba(41, 202, 122, 0.35);
	}

	.profile-heading h1 {
		margin: 0;
		color: #11182b;
		font-size: 2.2rem;
		letter-spacing: 0;
	}

	.profile-heading p {
		margin: 4px 0 14px;
		color: #5d7188;
		font-size: 1.1rem;
	}

	.profile-heading span {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		border: 1px solid rgba(255, 255, 255, 0.92);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.66);
		box-shadow: 0 8px 20px rgba(88, 118, 140, 0.12);
		color: #18263a;
		font-size: 0.96rem;
	}

	.profile-heading svg,
	.profile-details svg {
		width: 20px;
		height: 20px;
		flex: 0 0 auto;
		color: #16b884;
	}

	.profile-details {
		display: grid;
		gap: 18px;
		margin: 28px 0 0;
		padding: 26px 0 0;
		border-top: 1px solid rgba(119, 139, 160, 0.18);
		list-style: none;
		text-align: left;
	}

	.profile-details li {
		display: flex;
		align-items: center;
		gap: 14px;
		min-width: 0;
		color: #18263a;
		font-size: 0.98rem;
	}

	.profile-details a {
		min-width: 0;
		overflow-wrap: anywhere;
		color: inherit;
		text-decoration: none;
	}

	.profile-details a:hover {
		color: #159f77;
	}

	@media (max-width: 820px) {
		.profile-card {
			min-height: auto;
		}
	}
</style>
