---
import Icon from "../Icon.astro";

interface GithubStatsCardConfig {
  endpoint: string;
  alt: string;
  params: Record<string, string | number | boolean>;
}

interface GithubStatsConfig {
  username: string;
  profileUrl: string;
  baseUrl: string;
  cards: GithubStatsCardConfig[];
}

const { stats } = Astro.props as { stats: GithubStatsConfig };

function getCardUrl(card: GithubStatsCardConfig) {
  const url = new URL(card.endpoint, stats.baseUrl);
  url.searchParams.set("username", stats.username);

  for (const [key, value] of Object.entries(card.params)) {
    url.searchParams.set(key, String(value));
  }

  return url.toString();
}
---

<article class="glass-card stats-card">
  <header>
    <h2><Icon name="github" /> GitHub Stats</h2>
    <a
      href={stats.profileUrl}
      target="_blank"
      rel="noreferrer"
      aria-label="Open GitHub profile"
    >
      <Icon name="external" size={18} />
    </a>
  </header>

  <div class="stats-frames">
    {
      stats.cards.map((card) => (
        <a
          class="stats-frame"
          href={stats.profileUrl}
          target="_blank"
          rel="noreferrer"
        >
          <img
            src={getCardUrl(card)}
            alt={card.alt}
            loading="lazy"
            decoding="async"
          />
        </a>
      ))
    }
  </div>
</article>

<style>
  .stats-card {
    display: grid;
    gap: 14px;
    padding: 22px;
    overflow: hidden;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: #142033;
    font-size: 1.08rem;
  }

  h2 svg {
    width: 20px;
    height: 20px;
    color: #18b98a;
  }

  header a {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 12px;
    color: #13ae84;
    text-decoration: none;
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  header a:hover {
    background: rgba(255, 255, 255, 0.72);
    transform: translateY(-2px);
  }

  .stats-frames {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(220px, 0.75fr);
    gap: 12px;
    align-items: stretch;
  }

  .stats-frame {
    display: grid;
    min-width: 0;
    min-height: 172px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.42);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.72);
    overflow: hidden;
    text-decoration: none;
  }

  img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 172px;
    object-fit: contain;
    border-radius: 0;
  }

  @media (max-width: 640px) {
    .stats-card {
      padding: 20px;
    }

    .stats-frames {
      grid-template-columns: 1fr;
    }

    .stats-frame,
    img {
      min-height: 166px;
    }
  }
</style>
