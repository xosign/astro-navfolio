---
import Icon from '../Icon.astro';
---

<article class="glass-card clock-card" data-clock-widget>
	<h2><Icon name="clock" /> 当前时间</h2>
	<div class="time-row">
		<time class="time-value" data-time>
			<span data-time-main>--:--</span><small data-time-seconds>:--</small>
		</time>
		<span class="time-period" data-period>AM</span>
	</div>
	<p data-date>----</p>
</article>

<script>
	const widget = document.querySelector('[data-clock-widget]');
	const timeMainNode = widget?.querySelector('[data-time-main]');
	const secondsNode = widget?.querySelector('[data-time-seconds]');
	const periodNode = widget?.querySelector('[data-period]');
	const dateNode = widget?.querySelector('[data-date]');
	const weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];

	function updateClock() {
		const now = new Date();
		let hours = now.getHours();
		const period = hours >= 12 ? 'PM' : 'AM';
		hours = hours % 12 || 12;
		const minutes = String(now.getMinutes()).padStart(2, '0');
		const seconds = String(now.getSeconds()).padStart(2, '0');
		const date = `${now.getFullYear()}/${now.getMonth() + 1}/${now.getDate()} ${weekdays[now.getDay()]}`;

		if (timeMainNode) timeMainNode.textContent = `${String(hours).padStart(2, '0')}:${minutes}`;
		if (secondsNode) secondsNode.textContent = `:${seconds}`;
		if (periodNode) periodNode.textContent = period;
		if (dateNode) dateNode.textContent = date;
	}

	updateClock();
	window.setInterval(updateClock, 1000);
</script>

<style>
	.clock-card {
		min-height: 210px;
		padding: 30px 28px;
	}

	h2 {
		display: flex;
		align-items: center;
		gap: 12px;
		margin: 0 0 22px;
		color: #142033;
		font-size: 1.06rem;
	}

	h2 svg {
		width: 22px;
		height: 22px;
		color: #328f81;
	}

	.time-row {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.time-value {
		display: flex;
		align-items: baseline;
		color: #05080d;
		font-family: ui-monospace, 'SFMono-Regular', 'Cascadia Mono', Menlo, monospace;
		font-size: clamp(3.2rem, 7vw, 5rem);
		font-weight: 650;
		letter-spacing: 0;
		line-height: 1;
	}

	.time-value small {
		font-size: 0.48em;
		font-weight: 650;
		line-height: 1;
	}

	.time-period {
		padding: 6px 11px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		color: #171d2a;
		font-size: 0.95rem;
	}

	p {
		margin: 22px 0 0;
		color: #17243a;
		font-size: 1.1rem;
	}
</style>
