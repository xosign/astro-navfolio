---
import { getCollection } from 'astro:content';
import Icon from '../Icon.astro';
import {
  createRecentBlogHeatmap,
  type HeatmapDay,
  type HeatmapPost,
} from '../../utils/blog-heatmap';

interface Props {
  weeks?: number;
  showLatest?: boolean;
  latestCount?: number;
  excludeDraft?: boolean;
  dateArchiveBaseHref?: string;
  startDate?: Date | string | null;
}

const {
  weeks = 24,
  showLatest = true,
  latestCount = 1,
  excludeDraft = true,
  dateArchiveBaseHref,
  startDate,
} = Astro.props;
const posts = await getCollection('blog', ({ data }) => !excludeDraft || !data.draft);
const heatmap = createRecentBlogHeatmap(posts, weeks, latestCount, startDate);
const heatmapLabel = startDate
  ? `Writing activity since ${heatmap.startDate}`
  : `Recent ${heatmap.weeks} weeks writing activity`;
const formatDate = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function getPostLabel(count: number) {
  return `${count} ${count === 1 ? 'post' : 'posts'}`;
}

function getDayTitle(day: HeatmapDay) {
  if (day.isFuture) return `${day.date}: upcoming`;

  const titleLines = day.posts.slice(0, 5).map((post) => `- ${post.title}`);
  const overflowLine = day.posts.length > 5 ? ['...'] : [];

  return [`${day.date}: ${getPostLabel(day.count)}`, ...titleLines, ...overflowLine].join('\n');
}

function getDayHref(day: HeatmapDay) {
  if (dateArchiveBaseHref && day.count > 0) {
    return `${dateArchiveBaseHref.replace(/\/$/, '')}/${day.date}/`;
  }

  return day.posts[0]?.href;
}

function getTooltipPosts(posts: HeatmapPost[]) {
  return posts.slice(0, 5);
}
---

<article class="glass-card heatmap-card">
  <div class="stats-row">
    <div class="stat-item">
      <strong>{heatmap.totalPosts}</strong>
      <span>Total posts</span>
    </div>
    <div class="stat-item">
      <strong>{heatmap.activeDays}</strong>
      <span>Active days</span>
    </div>
    <div class="stat-item">
      <strong>{heatmap.currentStreak}</strong>
      <span>Day streak</span>
    </div>
  </div>

  {
    showLatest && heatmap.latestPosts.length > 0 && (
      <aside class="latest-tip" aria-label="Latest published posts">
        <strong>Latest</strong>
        <div class="latest-list">
          {heatmap.latestPosts.map((post) => (
            <a class="latest-link" href={post.href} aria-label={`Open latest post: ${post.title}`}>
              <em>{post.title}</em>
              <time datetime={post.date.toISOString()}>{formatDate.format(post.date)}</time>
              <span class="latest-icon" aria-hidden="true">
                <Icon name="external" size={15} />
              </span>
            </a>
          ))}
        </div>
      </aside>
    )
  }

  <div class="rhythm-grid" aria-label={heatmapLabel}>
    <div class="weekday-column" aria-hidden="true">
      <span>Mon</span>
      <span>Wed</span>
      <span>Fri</span>
    </div>

    <div class="heatmap-cells" style={`--week-count: ${heatmap.weeks};`}>
      {
        heatmap.days.map((day) => {
          if (day.isFuture) {
            return <span class="heatmap-cell future-cell" aria-hidden="true" />;
          }

          const href = getDayHref(day);
          const content = (
            <span
              class={`heatmap-cell level-${day.level}`}
              title={getDayTitle(day)}
              aria-hidden="true"
            />
          );
          const tooltip = (
            <span class="tooltip" role="tooltip">
              <strong>{formatDate.format(new Date(day.date))}</strong>
              <span>{getPostLabel(day.count)}</span>
              {day.posts.length > 0 && (
                <ul>
                  {getTooltipPosts(day.posts).map((post) => (
                    <li>{post.title}</li>
                  ))}
                  {day.posts.length > 5 && <li>...</li>}
                </ul>
              )}
            </span>
          );

          return href ? (
            <a class="cell-link" href={href} aria-label={getDayTitle(day)}>
              {content}
              {tooltip}
            </a>
          ) : (
            <span class="cell-link static-cell" aria-label={getDayTitle(day)}>
              {content}
              {tooltip}
            </span>
          );
        })
      }
    </div>
  </div>

  <footer>
    <span>Less</span>
    {[0, 1, 2, 3, 4].map((level) => <i class={`heatmap-cell level-${level}`} />)}
    <span>More</span>
  </footer>
</article>

<style>
  .heatmap-card {
    display: grid;
    gap: 16px;
    padding: 20px;
    border-color: transparent;
    background: transparent;
    box-shadow: none;
    overflow: visible;
  }

  .heatmap-card:hover {
    border-color: transparent;
    box-shadow: none;
    transform: none;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .stat-item {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .stat-item strong {
    color: var(--paper-ink);
    font-size: 1.12rem;
    line-height: 1;
  }

  .stat-item span {
    overflow: hidden;
    color: var(--paper-ink-soft);
    font-size: 0.72rem;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .latest-tip {
    display: grid;
    gap: 6px;
    padding: 10px 11px;
    border: 1px solid var(--paper-line);
    border-radius: 7px;
    background: var(--paper-surface-muted);
  }

  .latest-list {
    display: grid;
    gap: 4px;
  }

  .latest-link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) max-content 24px;
    align-items: center;
    min-width: 0;
    gap: 8px;
    color: inherit;
    text-decoration: none;
  }

  .latest-tip strong {
    color: var(--paper-accent);
    font-size: 0.7rem;
    line-height: 1.15;
  }

  .latest-tip em {
    overflow: hidden;
    color: var(--paper-ink);
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 650;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .latest-tip time {
    color: var(--paper-ink-soft);
    font-size: 0.68rem;
    line-height: 1;
    white-space: nowrap;
  }

  .latest-icon {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 8px;
    color: var(--paper-accent);
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .latest-link:hover .latest-icon,
  .latest-link:focus-visible .latest-icon {
    background: var(--paper-control-hover);
    transform: translateY(-1px);
  }

  .latest-link:focus-visible {
    border-radius: 7px;
    outline: 2px solid color-mix(in srgb, var(--paper-accent) 28%, transparent);
    outline-offset: 3px;
  }

  .rhythm-grid {
    --cell-size: 8px;
    --cell-gap: 2.5px;
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 8px;
    align-items: center;
    width: 100%;
    max-width: 100%;
    overflow: visible;
  }

  .weekday-column {
    display: grid;
    grid-template-rows: repeat(3, var(--cell-size));
    gap: calc(var(--cell-size) + var(--cell-gap));
    color: var(--paper-ink-faint);
    font-size: 0.62rem;
    line-height: 1;
  }

  .heatmap-cells {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, var(--cell-size));
    grid-auto-columns: var(--cell-size);
    gap: var(--cell-gap);
    width: calc(
      (var(--cell-size) * var(--week-count)) + (var(--cell-gap) * (var(--week-count) - 1))
    );
    max-width: 100%;
  }

  .heatmap-cell,
  .cell-link {
    display: block;
    width: var(--cell-size);
    height: var(--cell-size);
    min-width: 8px;
    min-height: 8px;
  }

  .cell-link {
    position: relative;
    color: inherit;
    text-decoration: none;
  }

  .cell-link:hover,
  .cell-link:focus-visible {
    z-index: 10;
  }

  .cell-link:hover .heatmap-cell {
    outline: 1px solid var(--paper-line-strong);
    outline-offset: 1px;
  }

  .heatmap-cell {
    border-radius: 2.5px;
    background: rgba(102, 125, 109, 0.12);
    box-shadow: inset 0 0 0 1px var(--paper-line);
  }

  .future-cell {
    background: transparent;
    box-shadow: none;
  }

  .level-0 {
    background: rgba(102, 125, 109, 0.16);
  }

  .level-1 {
    background: #dce8dc;
  }

  .level-2 {
    background: #b9cbb9;
  }

  .level-3 {
    background: #8fa58f;
  }

  .level-4 {
    background: #667d6d;
  }

  .tooltip {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 9px);
    z-index: 4;
    display: grid;
    width: max-content;
    max-width: 230px;
    gap: 5px;
    padding: 10px 12px;
    border: 1px solid var(--paper-line);
    border-radius: 7px;
    background: var(--paper-surface);
    box-shadow: var(--paper-shadow-lift);
    color: var(--paper-ink);
    font-size: 0.78rem;
    line-height: 1.35;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, 6px);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
  }

  .cell-link:nth-child(n + 19) .tooltip {
    left: auto;
    right: 0;
    transform: translate(0, 6px);
  }

  .cell-link:nth-child(n + 19):hover .tooltip,
  .cell-link:nth-child(n + 19):focus-visible .tooltip {
    transform: translate(0, 0);
  }

  .tooltip strong {
    color: var(--paper-ink);
    font-size: 0.86rem;
  }

  .tooltip ul {
    display: grid;
    gap: 3px;
    margin: 4px 0 0;
    padding-left: 16px;
  }

  .tooltip li {
    overflow-wrap: anywhere;
  }

  .cell-link:hover .tooltip,
  .cell-link:focus-visible .tooltip {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  footer {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--paper-ink-faint);
    font-size: 0.72rem;
  }

  footer .heatmap-cell {
    --cell-size: 9px;
  }

  @media (max-width: 1180px) and (min-width: 821px) {
    .rhythm-grid {
      --cell-size: 8px;
    }
  }

  @media (max-width: 820px) {
    .heatmap-card {
      gap: 14px;
      padding: 0;
      overflow: hidden;
    }

    .rhythm-grid {
      --cell-gap: 2.5px;
      grid-template-columns: 22px minmax(0, 1fr);
      overflow: hidden;
      width: 100%;
    }

    .heatmap-cells {
      grid-template-rows: repeat(7, auto);
      grid-auto-columns: minmax(0, 1fr);
      width: 100%;
      max-width: 360px;
    }

    .heatmap-cells .heatmap-cell,
    .heatmap-cells .cell-link {
      width: 100%;
      height: auto;
      min-width: 0;
      min-height: 0;
      aspect-ratio: 1;
    }

    .weekday-column {
      font-size: 0.58rem;
    }
  }
</style>
