---
interface TocItem {
  href: string;
  label: string;
  depth: number;
  children: TocItem[];
}

interface Props {
  items: TocItem[];
  compact?: boolean;
  collapsible?: boolean;
  font?: 'ui' | 'article';
}

const { items, compact = false, collapsible = false, font = 'ui' } = Astro.props;

const hasItems = items.length > 0;
const canCollapse = collapsible && items.length > 3;
const listId = collapsible ? 'mobile-article-toc-list' : undefined;
---

{
  hasItems && (
    <nav
      class:list={['toc-card', 'blog-card', { compact, collapsible, 'can-collapse': canCollapse }]}
      aria-label="Table of contents"
      data-toc-root
      data-font={font}
      data-mobile-toc={collapsible ? '' : undefined}
      data-expanded={collapsible ? 'false' : undefined}
    >
      <h2>Table of contents</h2>
      <ol id={listId}>
        {items.map((item, i) => {
          const h2Num = i + 1;
          const isParent = item.children.length > 0;
          return (
            <li
              data-toc-depth={item.depth}
              data-toc-parent={isParent ? '' : undefined}
              data-toc-expanded={isParent ? 'true' : undefined}
            >
              <a href={item.href} data-toc-link data-toc-hash={item.href}>
                <span>{h2Num}</span>
                {item.label}
              </a>
              {isParent && (
                <ol class="toc-children">
                  {item.children.map((child) => {
                    const isChildParent = child.children.length > 0;
                    return (
                      <li
                        data-toc-depth={child.depth}
                        data-toc-parent={isChildParent ? '' : undefined}
                        data-toc-expanded={isChildParent ? 'true' : undefined}
                      >
                        <a href={child.href} data-toc-link data-toc-hash={child.href}>
                          {child.label}
                        </a>
                        {isChildParent && (
                          <ol class="toc-children">
                            {child.children.map((grandchild) => (
                              <li data-toc-depth={grandchild.depth}>
                                <a href={grandchild.href} data-toc-link data-toc-hash={grandchild.href}>
                                  {grandchild.label}
                                </a>
                              </li>
                            ))}
                          </ol>
                        )}
                      </li>
                    );
                  })}
                </ol>
              )}
            </li>
          );
        })}
      </ol>
      {canCollapse && (
        <button
          class="toc-expand"
          type="button"
          aria-label="Expand table of contents"
          aria-expanded="false"
          aria-controls={listId}
          data-toc-expand
        >
          <span data-expand-label>Show all</span>
          <i aria-hidden="true" />
        </button>
      )}
    </nav>
  )
}

<script>
  import { mountNavfolioTocSpy } from '../../utils/toc-spy';

  mountNavfolioTocSpy();

  const initMobileTocToggle = () => {
    for (const toc of document.querySelectorAll<HTMLElement>('[data-mobile-toc]')) {
      const button = toc.querySelector<HTMLButtonElement>('[data-toc-expand]');
      const label = toc.querySelector<HTMLElement>('[data-expand-label]');

      if (!button || button.dataset.tocToggleReady) {
        continue;
      }

      button.dataset.tocToggleReady = 'true';
      button.addEventListener('click', () => {
        const expanded = toc.dataset.expanded === 'true';
        const nextExpanded = !expanded;

        toc.dataset.expanded = String(nextExpanded);
        button.setAttribute('aria-expanded', String(nextExpanded));
        button.setAttribute(
          'aria-label',
          nextExpanded ? 'Collapse table of contents' : 'Expand table of contents',
        );
        if (label) {
          label.textContent = nextExpanded ? 'Collapse' : 'Show all';
        }
      });
    }
  };

  initMobileTocToggle();
  document.addEventListener('astro:page-load', initMobileTocToggle);
</script>

<style>
  .toc-card {
    padding: 18px;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  h2 {
    margin: 0 0 14px;
    color: var(--paper-ink);
    font-family: var(--font-ui-label);
    font-size: 0.9rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  ol {
    display: grid;
    gap: 5px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-children {
    gap: 1px;
    margin-top: 2px;
    margin-bottom: 1px;
    overflow: hidden;
    max-height: 0;
    transition: max-height 320ms ease;
  }

  li[data-toc-parent][data-toc-expanded='true'] > .toc-children {
    max-height: 2000px;
  }

  li[data-toc-parent][data-toc-expanded='false'] > .toc-children {
    max-height: 0;
  }

  li {
    position: relative;
    --toc-line-x: 4px;
    --toc-dot-size: 7px;
    --toc-dot-border: 2px;
    padding-left: 14px;
  }

  li[data-toc-depth='3'] {
    --toc-dot-size: 5px;
    --toc-dot-border: 1.5px;
    padding-left: 36px;
  }

  li[data-toc-depth='4'] {
    --toc-dot-size: 4px;
    --toc-dot-border: 1px;
    padding-left: 56px;
  }

  li::before {
    position: absolute;
    top: 0;
    bottom: -5px;
    left: var(--toc-line-x);
    width: 1px;
    background: rgba(102, 125, 109, 0.16);
    content: '';
  }

  li[data-toc-depth='3']::before,
  li[data-toc-depth='4']::before {
    content: none;
  }

  li:last-child::before {
    display: none;
  }

  a {
    position: relative;
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 8px;
    align-items: center;
    padding: 9px 10px;
    border-radius: 7px;
    color: var(--paper-ink-soft);
    font-family: var(--font-serif-cn);
    font-size: 0.86rem;
    line-height: 1.35;
    text-decoration: none;
    transition:
      background-color 160ms ease,
      color 160ms ease;
  }

  li[data-toc-depth='3'] a {
    grid-template-columns: 1fr;
    font-size: 0.82rem;
  }

  li[data-toc-depth='4'] a {
    grid-template-columns: 1fr;
    font-size: 0.78rem;
    opacity: 0.85;
  }

  .toc-card[data-font='article'] a {
    font-family: var(--font-article);
  }

  a[data-state='past'] {
    color: var(--paper-ink-faint);
    opacity: 0.62;
  }

  a[data-state='past'] span {
    color: var(--paper-ink-faint);
    opacity: 0.58;
  }

  a[data-state='future'] {
    color: var(--paper-ink-soft);
    opacity: 1;
  }

  a[data-state='future'] span {
    color: var(--paper-ink-faint);
  }

  a::before {
    position: absolute;
    left: calc(
      (var(--toc-line-x) - 14px) - ((var(--toc-dot-size) + var(--toc-dot-border) * 2) / 2)
    );
    width: var(--toc-dot-size);
    height: var(--toc-dot-size);
    border: var(--toc-dot-border) solid rgba(102, 125, 109, 0.38);
    border-radius: 50%;
    background: var(--paper-surface);
    content: '';
  }

  a::after {
    position: absolute;
    top: 50%;
    left: calc(var(--toc-line-x) - 14px);
    transform: translate(-50%, -50%) scale(0.7);
    opacity: 0;
    color: var(--paper-surface);
    content: '✓';
    font-size: 0.56rem;
    font-weight: 900;
    line-height: 1;
    transition:
      opacity 160ms ease,
      transform 160ms ease,
      color 160ms ease;
  }

  a[data-state='active'],
  a[aria-current='true'] {
    background: rgba(102, 125, 109, 0.24);
    color: var(--paper-accent);
  }

  a[data-state]:not([data-state='active']):not([aria-current='true']):hover {
    background: rgba(102, 125, 109, 0.14);
    color: var(--paper-accent);
  }

  a[data-state='active']::before,
  a[aria-current='true']::before {
    border-color: var(--paper-accent);
    background: var(--paper-accent);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.24) inset,
      0 0 0 3px rgba(102, 125, 109, 0.08);
  }

  a[data-state]:not([data-state='active']):not([aria-current='true']):hover::before {
    border-color: rgba(102, 125, 109, 0.58);
    background: rgba(102, 125, 109, 0.18);
    box-shadow: none;
  }

  a[data-state='active']::after,
  a[aria-current='true']::after {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  a[data-state='active'],
  a[aria-current='true'] {
    box-shadow: inset 2px 0 0 var(--paper-accent);
  }

  a[data-state='past']:not([aria-current='true']) {
    background: transparent;
  }

  a[data-state='past']:not([aria-current='true'])::before {
    border-color: rgba(102, 125, 109, 0.26);
    background: rgba(102, 125, 109, 0.12);
    box-shadow: none;
  }

  a[data-state='future']:not([aria-current='true'])::before {
    border-color: rgba(102, 125, 109, 0.38);
    background: var(--paper-surface);
  }

  span {
    color: var(--paper-ink-faint);
    font-family: var(--font-ui-label);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .compact {
    padding: 18px;
  }

  .toc-expand {
    display: none;
  }

  @media (max-width: 900px) {
    .collapsible {
      padding: 16px;
      border: 1px solid var(--paper-line);
      background: var(--paper-surface);
      box-shadow: var(--paper-shadow);
      scroll-margin-top: 78px;
    }

    .can-collapse > ol {
      max-height: 129px;
      overflow: hidden;
      transition: max-height 180ms ease;
    }

    .can-collapse[data-expanded='true'] > ol {
      max-height: none;
    }

    .can-collapse .toc-expand {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      justify-content: center;
      width: 100%;
      margin-top: 10px;
      padding: 8px 10px;
      border: 1px solid var(--paper-line);
      border-radius: 7px;
      background: var(--paper-control);
      color: var(--paper-ink-soft);
      font-family: var(--font-ui-label);
      font-size: 0.78rem;
      font-weight: 700;
      cursor: pointer;
      transition:
        background-color 160ms ease,
        color 160ms ease;
    }

    .can-collapse .toc-expand:hover {
      background: var(--paper-control-hover);
      color: var(--paper-accent);
    }

    .toc-expand i {
      width: 7px;
      height: 7px;
      border-right: 1.5px solid currentColor;
      border-bottom: 1.5px solid currentColor;
      transform: translateY(-2px) rotate(45deg);
      transition: transform 160ms ease;
    }

    .can-collapse[data-expanded='true'] .toc-expand i {
      transform: translateY(2px) rotate(225deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collapsible > ol,
    .toc-children,
    .toc-expand i {
      transition: none;
    }
  }
</style>
