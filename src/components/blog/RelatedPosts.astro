---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import SmartImage from '../SmartImage.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  class?: string;
}

const { posts, class: className } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<aside class:list={['related-posts', 'blog-card', className]}>
  <h2>More from navfolio</h2>
  <div class="related-list">
    {
      posts.map((post) => (
        <a
          class:list={[{ 'has-thumbnail': Boolean(post.data.heroImage) }]}
          href={withBase(`/blog/${post.id}/`)}
        >
          {post.data.heroImage && (
            <SmartImage width={88} height={64} src={post.data.heroImage} alt="" />
          )}
          <span>
            <strong>{post.data.title}</strong>
            <small>
              <FormattedDate date={post.data.date} />
            </small>
          </span>
        </a>
      ))
    }
  </div>
</aside>

<style>
  .related-posts {
    padding: 18px;
  }

  h2 {
    margin: 0 0 14px;
    color: var(--paper-ink);
    font-size: 0.9rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .related-list {
    display: grid;
    gap: 12px;
  }

  a {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5px;
    align-items: center;
    color: var(--paper-ink);
    text-decoration: none;
  }

  a.has-thumbnail {
    grid-template-columns: 58px minmax(0, 1fr);
    gap: 10px;
  }

  a:hover strong {
    color: var(--paper-accent);
  }

  img {
    display: block;
    width: 58px;
    height: 48px;
    border-radius: 6px;
    background: var(--paper-surface-muted);
    object-fit: cover;
    box-shadow: var(--paper-shadow);
    filter: saturate(0.7);
  }

  span {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  strong {
    display: -webkit-box;
    overflow: hidden;
    font-size: 0.86rem;
    line-height: 1.25;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  small {
    color: var(--paper-ink-faint);
    font-size: 0.75rem;
  }
</style>
