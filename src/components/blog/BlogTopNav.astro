---
import { Moon, Search } from 'lucide-astro';

const links = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: 'https://github.com/navfolio' },
  { label: 'About', href: '/about' },
];
---

<header class="blog-top-nav">
  <a class="brand" href="/" aria-label="Go to navfolio home">
    <span class="brand-mark" aria-hidden="true"></span>
    <span>navfolio</span>
  </a>

  <nav class="nav-links" aria-label="Article navigation">
    {
      links.map((link) => (
        <a class:list={['nav-link', { active: link.label === 'Blog' }]} href={link.href}>
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="nav-actions" aria-label="Page actions">
    <button type="button" aria-label="Toggle theme">
      <Moon size={17} stroke-width={2} />
    </button>
    <button type="button" aria-label="Search">
      <Search size={17} stroke-width={2} />
    </button>
  </div>
</header>

<style>
  .blog-top-nav {
    position: fixed;
    top: 18px;
    left: 50%;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    width: min(calc(100% - 32px), 900px);
    min-height: 58px;
    padding: 10px 14px 10px 18px;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.76);
    box-shadow:
      0 18px 48px rgba(52, 88, 82, 0.13),
      inset 0 1px 1px rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(18px);
    transform: translateX(-50%);
  }

  .brand,
  .nav-link {
    color: #152437;
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 700;
  }

  .brand-mark {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #35c99a;
    box-shadow: 0 0 18px rgba(53, 201, 154, 0.44);
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: 4px;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    justify-content: center;
    min-width: 74px;
    padding: 9px 12px 12px;
    border-radius: 16px;
    color: #526171;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(233, 250, 244, 0.78);
    color: #14775e;
  }

  .nav-link.active::after {
    position: absolute;
    bottom: 5px;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #27bd8c;
    content: '';
    transform: translateX(-50%);
  }

  .nav-actions {
    display: flex;
    gap: 8px;
  }

  .nav-actions button {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid rgba(103, 144, 134, 0.16);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.68);
    color: #223346;
    cursor: pointer;
  }

  .nav-actions button:hover {
    background: rgba(228, 249, 242, 0.9);
    color: #14775e;
  }

  @media (max-width: 720px) {
    .blog-top-nav {
      grid-template-columns: 1fr auto;
      gap: 10px;
      top: 10px;
      width: min(calc(100% - 20px), 520px);
      min-height: 54px;
      padding: 8px 10px 8px 14px;
      border-radius: 20px;
    }

    .nav-links {
      display: none;
    }
  }
</style>
