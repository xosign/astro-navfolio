---
import { Github, ListTree, Menu, Moon, Sun } from 'lucide-astro';
import SiteSearch from './SiteSearch.astro';
import { getSiteConfig } from '../../data/site';

interface TocItem {
  href: string;
  label: string;
  depth: number;
  children: TocItem[];
}

interface Props {
  showTocIcon?: boolean;
  tocItems?: TocItem[];
}

const { showTocIcon = false, tocItems = [] } = Astro.props;
const { site, topNav, search } = await getSiteConfig();
const links = topNav.links;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPathname =
  basePath && Astro.url.pathname.startsWith(basePath)
    ? Astro.url.pathname.slice(basePath.length) || '/'
    : Astro.url.pathname;
const currentPath = currentPathname.replace(/\/$/, '') || '/';

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}

function isActive(href: string) {
  if (href.startsWith('http')) return false;

  const normalizedHref = href.replace(/\/$/, '') || '/';

  if (normalizedHref === '/') {
    return currentPath === '/';
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}

const routeLabels: Record<string, string> = {
  '/blog': 'blog',
  '/projects': 'projects',
  '/vibe': 'vibe',
  '/archive': 'archive',
  '/about': 'about',
};
const activeRoute = Object.entries(routeLabels).find(
  ([route]) => currentPath === route || currentPath.startsWith(`${route}/`),
);
const brandRouteLabel = activeRoute?.[1];
const shouldShowTocAction = showTocIcon && tocItems.length > 0;
---

<header class="blog-top-nav" data-pagefind-ignore>
  <button
    class="mobile-menu-toggle"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-nav-menu"
    data-mobile-menu-toggle
  >
    <Menu size={18} stroke-width={2} />
  </button>

  <a class="brand" href={withBase('/')} aria-label={`Go to ${site.title} home`}>
    <span class="brand-mark" aria-hidden="true"></span>
    <span class="brand-title">
      <span>{site.title}</span>
      {brandRouteLabel && <span class="brand-route"> · {brandRouteLabel}</span>}
    </span>
  </a>

  <nav class="nav-links" aria-label="Article navigation">
    {
      links.map((link) =>
        link.disabled ? (
          <span
            class="nav-link nav-link-placeholder"
            aria-disabled="true"
            title="Projects content placeholder"
          >
            {link.label}
          </span>
        ) : (
          <a class:list={['nav-link', { active: isActive(link.href) }]} href={withBase(link.href)}>
            {link.label}
          </a>
        ),
      )
    }
  </nav>

  <nav
    class="mobile-menu-panel"
    id="mobile-nav-menu"
    aria-label="Mobile navigation"
    data-mobile-menu
  >
    {
      links.map((link) =>
        link.disabled ? (
          <span class="mobile-menu-link mobile-menu-placeholder" aria-disabled="true">
            {link.label}
          </span>
        ) : (
          <a
            class:list={['mobile-menu-link', { active: isActive(link.href) }]}
            href={withBase(link.href)}
            data-mobile-menu-link
          >
            {link.label}
          </a>
        ),
      )
    }
  </nav>

  <div class="nav-actions" aria-label="Page actions">
    <a
      href={site.repository}
      target="_blank"
      rel="noreferrer"
      aria-label="Open GitHub repository"
      title="GitHub"
    >
      <Github size={17} stroke-width={2} />
    </a>
    <button type="button" data-theme-toggle aria-label="Switch theme">
      <Moon class="theme-icon-moon" size={17} stroke-width={2} />
      <Sun class="theme-icon-sun" size={17} stroke-width={2} />
    </button>
    {search.enabled && <SiteSearch search={search} />}
    {
      shouldShowTocAction && (
        <button
          class="toc-action"
          type="button"
          aria-label="Open table of contents"
          aria-expanded="false"
          aria-controls="mobile-toc-menu"
          title="Table of contents"
          data-mobile-toc-trigger
        >
          <ListTree size={17} stroke-width={2} />
        </button>
      )
    }
  </div>

  {
    shouldShowTocAction && (
      <nav
        class="mobile-toc-panel"
        id="mobile-toc-menu"
        aria-label="Article table of contents"
        data-nav-toc-menu
        data-toc-root
      >
        <p>Table of contents</p>
        <ol>
          {tocItems.map((item, i) => {
            const h2Num = i + 1;
            const isParent = item.children.length > 0;
            return (
              <li
                data-toc-depth={item.depth}
                data-toc-parent={isParent ? '' : undefined}
                data-toc-expanded={isParent ? 'true' : undefined}
              >
                <a href={item.href} data-nav-toc-link data-toc-link data-toc-hash={item.href}>
                  <span>{h2Num}</span>
                  {item.label}
                </a>
                {isParent && (
                  <ol class="toc-children">
                    {item.children.map((child) => {
                      const isChildParent = child.children.length > 0;
                      return (
                        <li
                          data-toc-depth={child.depth}
                          data-toc-parent={isChildParent ? '' : undefined}
                          data-toc-expanded={isChildParent ? 'true' : undefined}
                        >
                          <a href={child.href} data-nav-toc-link data-toc-link data-toc-hash={child.href}>
                            {child.label}
                          </a>
                          {isChildParent && (
                            <ol class="toc-children">
                              {child.children.map((grandchild) => (
                                <li data-toc-depth={grandchild.depth}>
                                  <a href={grandchild.href} data-nav-toc-link data-toc-link data-toc-hash={grandchild.href}>
                                    {grandchild.label}
                                  </a>
                                </li>
                              ))}
                            </ol>
                          )}
                        </li>
                      );
                    })}
                  </ol>
                )}
              </li>
            );
          })}
        </ol>
      </nav>
    )
  }
</header>

<script>
  const initMobileTopNav = () => {
    for (const header of document.querySelectorAll<HTMLElement>('.blog-top-nav')) {
      const toggle = header.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
      const menu = header.querySelector<HTMLElement>('[data-mobile-menu]');
      const tocTrigger = header.querySelector<HTMLButtonElement>('[data-mobile-toc-trigger]');
      const tocMenu = header.querySelector<HTMLElement>('[data-nav-toc-menu]');

      if (!header.dataset.scrollHideReady) {
        header.dataset.scrollHideReady = 'true';

        const topRevealOffset = 24;
        const hideAfterOffset = 96;
        const scrollIntentDelta = 8;
        let lastScrollY = window.scrollY;
        let scrollFrame = 0;

        const setNavHidden = (hidden: boolean) => {
          header.dataset.navHidden = hidden ? 'true' : 'false';
          header.toggleAttribute('inert', hidden);
          header.toggleAttribute('aria-hidden', hidden);
        };

        const shouldKeepVisible = () =>
          window.scrollY <= topRevealOffset ||
          header.dataset.mobileMenuOpen === 'true' ||
          header.dataset.mobileTocOpen === 'true' ||
          header.matches(':focus-within');

        const updateNavVisibility = () => {
          scrollFrame = 0;
          const currentScrollY = window.scrollY;
          const scrollDelta = currentScrollY - lastScrollY;

          if (shouldKeepVisible()) {
            setNavHidden(false);
            lastScrollY = currentScrollY;
            return;
          }

          if (Math.abs(scrollDelta) < scrollIntentDelta) {
            return;
          }

          setNavHidden(scrollDelta > 0 && currentScrollY > hideAfterOffset);
          lastScrollY = currentScrollY;
        };

        window.addEventListener(
          'scroll',
          () => {
            if (scrollFrame) {
              return;
            }

            scrollFrame = window.requestAnimationFrame(updateNavVisibility);
          },
          { passive: true },
        );

        window.addEventListener('resize', () => {
          if (window.scrollY <= topRevealOffset) {
            setNavHidden(false);
          }
        });

        setNavHidden(false);
      }

      if (toggle && menu && !header.dataset.mobileMenuReady) {
        header.dataset.mobileMenuReady = 'true';

        const setMenuOpen = (open: boolean) => {
          header.dataset.mobileMenuOpen = open ? 'true' : 'false';
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute(
            'aria-label',
            open ? 'Close navigation menu' : 'Open navigation menu',
          );
        };
        const setTocOpen = (open: boolean) => {
          if (!tocTrigger || !tocMenu) {
            return;
          }

          header.dataset.mobileTocOpen = open ? 'true' : 'false';
          tocTrigger.setAttribute('aria-expanded', String(open));
          tocTrigger.setAttribute(
            'aria-label',
            open ? 'Close table of contents' : 'Open table of contents',
          );
        };

        toggle.addEventListener('click', () => {
          const nextOpen = header.dataset.mobileMenuOpen !== 'true';
          setMenuOpen(nextOpen);
          header.dataset.navHidden = 'false';
          if (nextOpen) {
            setTocOpen(false);
          }
        });

        menu.addEventListener('click', (event) => {
          if ((event.target as Element).closest?.('[data-mobile-menu-link]')) {
            setMenuOpen(false);
          }
        });

        tocTrigger?.addEventListener('click', () => {
          const nextOpen = header.dataset.mobileTocOpen !== 'true';
          setTocOpen(nextOpen);
          header.dataset.navHidden = 'false';
          if (nextOpen) {
            setMenuOpen(false);
          }
        });

        tocMenu?.addEventListener('click', (event) => {
          if ((event.target as Element).closest?.('[data-nav-toc-link]')) {
            setTocOpen(false);
          }
        });

        document.addEventListener('click', (event) => {
          if (!header.contains(event.target as Node)) {
            setMenuOpen(false);
            setTocOpen(false);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            setMenuOpen(false);
            setTocOpen(false);
          }
        });
      }
    }
  };

  initMobileTopNav();
  document.addEventListener('astro:page-load', initMobileTopNav);
</script>

<style>
  .blog-top-nav {
    position: fixed;
    top: 18px;
    right: 0;
    left: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    width: min(calc(100% - 32px), 900px);
    min-height: 56px;
    padding: 10px 14px 10px 18px;
    margin: 0 auto;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-nav);
    box-shadow: var(--paper-shadow);
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 180ms ease,
      transform 220ms ease;
    will-change: transform;
  }

  .blog-top-nav[data-nav-hidden='true'] {
    opacity: 0;
    pointer-events: none;
    transform: translateY(calc(-100% - 24px));
  }

  .mobile-menu-toggle,
  .mobile-menu-panel,
  .mobile-toc-panel {
    display: none;
  }

  .brand,
  a.nav-link,
  a.mobile-menu-link,
  .mobile-toc-panel a {
    color: var(--paper-ink);
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 700;
  }

  .brand-mark {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--paper-accent);
    box-shadow: none;
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: 4px;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    justify-content: center;
    min-width: 74px;
    padding: 9px 12px 12px;
    border-radius: 8px;
    color: var(--paper-ink-soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  a.nav-link:hover,
  a.nav-link.active {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
  }

  .nav-link.active::after {
    position: absolute;
    bottom: 5px;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--paper-accent);
    content: '';
    transform: translateX(-50%);
  }

  .nav-link-placeholder {
    color: var(--paper-ink-faint);
    cursor: default;
  }

  .nav-actions {
    display: flex;
    gap: 8px;
  }

  .nav-actions a,
  .nav-actions button,
  .mobile-menu-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    cursor: pointer;
  }

  .mobile-menu-toggle,
  .nav-actions .toc-action {
    display: none;
  }

  .nav-actions a:hover,
  .nav-actions button:hover,
  .mobile-menu-toggle:hover {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
  }

  @media (max-width: 720px) {
    .blog-top-nav {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 10px;
      top: 10px;
      width: min(calc(100% - 20px), 520px);
      min-height: 54px;
      padding: 8px 10px 8px 14px;
      border-radius: 8px;
    }

    .nav-links {
      display: none;
    }

    .mobile-menu-toggle {
      display: inline-grid;
    }

    .brand {
      min-width: 0;
      gap: 8px;
      font-size: 0.95rem;
    }

    .brand-title {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .brand-mark {
      flex: 0 0 auto;
    }

    .nav-actions {
      gap: 6px;
    }

    .nav-actions a {
      display: none;
    }

    .nav-actions a,
    .nav-actions button,
    .mobile-menu-toggle {
      width: 36px;
      height: 36px;
      border-radius: 7px;
    }

    .nav-actions .toc-action {
      display: inline-grid;
    }

    .mobile-menu-panel {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      display: grid;
      min-width: min(260px, calc(100vw - 20px));
      gap: 4px;
      padding: 8px;
      border: 1px solid var(--paper-line);
      border-radius: 8px;
      background: var(--paper-nav);
      box-shadow: var(--paper-shadow);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
      transition:
        opacity 160ms ease,
        transform 160ms ease;
    }

    .mobile-toc-panel {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      display: grid;
      width: min(300px, calc(100vw - 20px));
      max-height: min(52vh, 420px);
      gap: 8px;
      overflow: auto;
      padding: 10px;
      border: 1px solid var(--paper-line);
      border-radius: 8px;
      background: var(--paper-nav);
      box-shadow: var(--paper-shadow);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
      transition:
        opacity 160ms ease,
        transform 160ms ease;
    }

    .blog-top-nav[data-mobile-menu-open='true'] .mobile-menu-panel {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .blog-top-nav[data-mobile-toc-open='true'] .mobile-toc-panel {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .mobile-menu-link {
      display: flex;
      align-items: center;
      min-height: 38px;
      padding: 8px 10px;
      border-radius: 7px;
      color: var(--paper-ink-soft);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .mobile-menu-link:hover,
    .mobile-menu-link.active {
      background: var(--paper-control-hover);
      color: var(--paper-accent);
    }

    .mobile-menu-placeholder {
      color: var(--paper-ink-faint);
    }

    .mobile-toc-panel p {
      margin: 0;
      padding: 2px 2px 4px;
      color: var(--paper-ink-faint);
      font-family: var(--font-ui-label);
      font-size: 0.72rem;
      font-weight: 700;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .mobile-toc-panel ol {
      display: grid;
      gap: 4px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .mobile-toc-panel .toc-children {
      gap: 1px;
      margin-top: 1px;
      overflow: hidden;
      max-height: 0;
      transition: max-height 240ms ease;
    }

    .mobile-toc-panel li[data-toc-parent][data-toc-expanded='true'] > .toc-children {
      max-height: 1500px;
    }

    .mobile-toc-panel li[data-toc-depth='3'] {
      padding-left: 18px;
    }

    .mobile-toc-panel li[data-toc-depth='4'] {
      padding-left: 32px;
    }

    .mobile-toc-panel li[data-toc-depth='3'] a {
      grid-template-columns: 1fr;
      font-size: 0.82rem;
    }

    .mobile-toc-panel li[data-toc-depth='4'] a {
      grid-template-columns: 1fr;
      font-size: 0.78rem;
      opacity: 0.85;
    }

    .mobile-toc-panel a {
      display: grid;
      grid-template-columns: 22px minmax(0, 1fr);
      gap: 8px;
      align-items: center;
      min-height: 36px;
      padding: 8px 10px;
      border-radius: 7px;
      color: var(--paper-ink-soft);
      font-size: 0.86rem;
      line-height: 1.35;
    }

    .mobile-toc-panel a:hover,
    .mobile-toc-panel a[aria-current='true'],
    .mobile-toc-panel a[data-state='active'] {
      background: var(--paper-control-hover);
      color: var(--paper-accent);
    }

    .mobile-toc-panel span {
      color: var(--paper-ink-faint);
      font-family: var(--font-ui-label);
      font-size: 0.72rem;
      font-weight: 700;
    }
  }

  @media (min-width: 721px) {
    .brand-route {
      display: none;
    }

    .nav-actions .toc-action {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-top-nav {
      transition: none;
    }
  }
</style>
