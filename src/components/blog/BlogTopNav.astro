---
import { Github, Moon, Search, Sun } from 'lucide-astro';
import { getSiteConfig } from '../../data/site';

const { site, topNav } = await getSiteConfig();
const links = topNav.links;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPathname =
  basePath && Astro.url.pathname.startsWith(basePath)
    ? Astro.url.pathname.slice(basePath.length) || '/'
    : Astro.url.pathname;
const currentPath = currentPathname.replace(/\/$/, '') || '/';

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}

function isActive(href: string) {
  if (href.startsWith('http')) return false;

  const normalizedHref = href.replace(/\/$/, '') || '/';

  if (normalizedHref === '/') {
    return currentPath === '/';
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<header class="blog-top-nav">
  <a class="brand" href={withBase('/')} aria-label={`Go to ${site.title} home`}>
    <span class="brand-mark" aria-hidden="true"></span>
    <span>{site.title}</span>
  </a>

  <nav class="nav-links" aria-label="Article navigation">
    {
      links.map((link) =>
        link.disabled ? (
          <span
            class="nav-link nav-link-placeholder"
            aria-disabled="true"
            title="Projects content placeholder"
          >
            {link.label}
          </span>
        ) : (
          <a class:list={['nav-link', { active: isActive(link.href) }]} href={withBase(link.href)}>
            {link.label}
          </a>
        ),
      )
    }
  </nav>

  <div class="nav-actions" aria-label="Page actions">
    <a
      href={site.repository}
      target="_blank"
      rel="noreferrer"
      aria-label="Open GitHub repository"
      title="GitHub"
    >
      <Github size={17} stroke-width={2} />
    </a>
    <button type="button" data-theme-toggle aria-label="Switch theme">
      <Moon class="theme-icon-moon" size={17} stroke-width={2} />
      <Sun class="theme-icon-sun" size={17} stroke-width={2} />
    </button>
    <button type="button" aria-label="Search">
      <Search size={17} stroke-width={2} />
    </button>
  </div>
</header>

<style>
  .blog-top-nav {
    position: fixed;
    top: 18px;
    left: 50%;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    width: min(calc(100% - 32px), 900px);
    min-height: 56px;
    padding: 10px 14px 10px 18px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-nav);
    box-shadow: var(--paper-shadow);
    transform: translateX(-50%);
  }

  .brand,
  a.nav-link {
    color: var(--paper-ink);
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 700;
  }

  .brand-mark {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--paper-accent);
    box-shadow: none;
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: 4px;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    justify-content: center;
    min-width: 74px;
    padding: 9px 12px 12px;
    border-radius: 8px;
    color: var(--paper-ink-soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  a.nav-link:hover,
  a.nav-link.active {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
  }

  .nav-link.active::after {
    position: absolute;
    bottom: 5px;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--paper-accent);
    content: '';
    transform: translateX(-50%);
  }

  .nav-link-placeholder {
    color: var(--paper-ink-faint);
    cursor: default;
  }

  .nav-actions {
    display: flex;
    gap: 8px;
  }

  .nav-actions a,
  .nav-actions button {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    cursor: pointer;
  }

  .nav-actions a:hover,
  .nav-actions button:hover {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
  }

  @media (max-width: 720px) {
    .blog-top-nav {
      grid-template-columns: 1fr auto;
      gap: 10px;
      top: 10px;
      width: min(calc(100% - 20px), 520px);
      min-height: 54px;
      padding: 8px 10px 8px 14px;
      border-radius: 8px;
    }

    .nav-links {
      display: none;
    }
  }
</style>
