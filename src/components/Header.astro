---
import { getSiteConfig } from '../data/site';
import HeaderLink from './HeaderLink.astro';
import Icon from './Icon.astro';

const { profile, site, topNav } = await getSiteConfig();
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<header>
  <nav>
    <h2><a href={withBase('/')}>{site.title}</a></h2>
    <div class="internal-links">
      {topNav.links.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
    </div>
    <div class="social-links">
      <a href={profile.website} target="_blank" rel="noreferrer">
        <span class="sr-only">Open website</span>
        <Icon name="compass" size={18} />
      </a>
      <a href={profile.github} target="_blank" rel="noreferrer">
        <span class="sr-only">Open GitHub profile</span>
        <Icon name="github" size={18} />
      </a>
      <a href={`mailto:${profile.email}`}>
        <span class="sr-only">Email</span>
        <Icon name="mail" size={18} />
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: var(--paper-nav);
    border-bottom: 1px solid var(--paper-line);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--paper-ink);
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--paper-accent);
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  .social-links a {
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
</style>
